{
  "name": "lol-vod-review",
  "version": "0.1.2",
  "description": "Automatic League of Legends VOD recorder & review tool",
  "author": "Thieu Le",
  "license": "MIT",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "doctor": "node scripts/doctor.mjs",
    "import-icon": "node scripts/import-icon.mjs",
    "package": "electron-vite build && electron-builder",
    "package:win": "electron-vite build && electron-builder --win",
    "publish:win": "electron-vite build && electron-builder --win --publish always",
    "rebuild": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "dump": "tsx tools/league-event-dumper/index.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.8.3",
    "googleapis": "^173.0.0",
    "obs-websocket-js": "^5.0.6",
    "uuid": "^11.0.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^5.4.11"
  }
}
